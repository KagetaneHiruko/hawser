# Hawser environment configuration
# Managed by Ansible — do not edit manually

TOKEN={{ hawser_token }}
AGENT_NAME={{ hawser_agent_name }}
LOG_LEVEL={{ hawser_log_level }}
{% if hawser_mode == 'edge' %}

DOCKHAND_SERVER_URL={{ hawser_dockhand_url }}
{% if hawser_ca_cert | length > 0 %}
CA_CERT={{ hawser_ca_cert }}
{% endif %}
{% if hawser_tls_skip_verify | bool %}
TLS_SKIP_VERIFY=true
{% endif %}
{% else %}

PORT={{ hawser_port }}
{% if hawser_tls_cert | length > 0 %}
TLS_CERT={{ hawser_tls_cert }}
{% endif %}
{% if hawser_tls_key | length > 0 %}
TLS_KEY={{ hawser_tls_key }}
{% endif %}
{% endif %}
